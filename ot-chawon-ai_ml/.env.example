# fill local values only; do not commit real secrets
APP_ENV=local

# Application
APP_NAME=ot-chawon AI Inference Server
APP_VERSION=0.1.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# AWS S3
AWS_REGION=ap-northeast-2
S3_BUCKET=ot-chawon-assets
CLOUDFRONT_URL=https://cdn.ot-chawon.com

# SMPL-X 모델 경로
SMPLX_MODEL_PATH=/models/smplx

# 서비스 연동 URL
AI_SERVER_URL=http://localhost:8000
FITTING_SERVICE_URL=http://localhost:8001

# GPU
GPU_BATCH_SIZE=8
