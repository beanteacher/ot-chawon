# ========================
# 데이터베이스 설정
# ========================
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_USER=otc_user
MYSQL_PASSWORD=otc_password_change_me

# 서비스별 DB 이름
USER_DB_NAME=otc_user_db
PRODUCT_DB_NAME=otc_product_db
ORDER_DB_NAME=otc_order_db
PAYMENT_DB_NAME=otc_payment_db
FITTING_DB_NAME=otc_fitting_db
BRAND_DB_NAME=otc_brand_db

# ========================
# Redis 설정
# ========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me

# ========================
# Kafka 설정
# ========================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# ========================
# JWT 설정
# ========================
JWT_SECRET=jwt_secret_change_me_at_least_32_chars_long
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# ========================
# 서비스 포트 설정
# ========================
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
FITTING_SERVICE_PORT=8085
BRAND_SERVICE_PORT=8086
FRONTEND_PORT=3000

# ========================
# 서비스 URL (내부 통신)
# ========================
USER_SERVICE_URL=http://user-service:8081
PRODUCT_SERVICE_URL=http://product-service:8082
ORDER_SERVICE_URL=http://order-service:8083
PAYMENT_SERVICE_URL=http://payment-service:8084
FITTING_SERVICE_URL=http://fitting-service:8085
BRAND_SERVICE_URL=http://brand-service:8086

# ========================
# Spring 설정
# ========================
SPRING_PROFILES_ACTIVE=local

# ========================
# 기타
# ========================
TZ=Asia/Seoul
